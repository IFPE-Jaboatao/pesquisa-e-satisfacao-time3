# Example environment variables for production (Dokploy)

# ------------------ MySQL ------------------
# Change these to secure values in Dokploy
MYSQL_ROOT_PASSWORD=senha!@
MYSQL_ROOT_HOST=%
MYSQL_DATABASE=pesquisa
MYSQL_USER=pesquisa!@
MYSQL_PASSWORD=pesquisa!@

# ------------------ MongoDB ------------------
# Root credentials for Mongo (used to create admin on first init)
MONGO_ROOT_USERNAME=devuser
MONGO_ROOT_PASSWORD=pesqsat
# Logical DB name
MONGO_DATABASE=satisfaction_survey_prod
# Optional explicit URI. If set, overrides MONGO_ROOT_* below.
# Encode special chars in user/password (@ → %40, : → %3A, etc.)
# MONGO_URI=mongodb://devuser:pesqsat%403@mongo:27017/satisfaction_survey_prod?authSource=admin

# mongo-express basic auth (web UI)
MONGO_EXPRESS_USER=devuser
MONGO_EXPRESS_PASSWORD=pesqsat

# ------------------ Backend / App ------------------
NODE_ENV=production
JWT_SECRET=segredo-de-estado
JWT_EXPIRATION=8h
DB_LOGGING=false

# URLs
FRONTEND_URL=https://pesquisa-satisfacao3.lab7.cloud
CORS_ORIGIN=https://api-pesquisa-satisfacao3.lab7.cloud

# ------------------ Frontend ------------------
# URL base da API do backend (pública para o browser, ou alias interno no Docker)
# Interno (server-side no mesmo stack): http://pesquisa-satisfacao3-backend:3001
# Público (browser): https://api-pesquisa-satisfacao3.lab7.cloud
API_BASE_URL=https://api-pesquisa-satisfacao3.lab7.cloud

# ------------------ Mail (optional) ------------------
MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASS=

# Notes:
# - Never commit real secrets. Use Dokploy secret variables for production.
# - Adminer: use server "mysql". By default root only exists as root@localhost;
#   from another container use MYSQL_USER/MYSQL_PASSWORD, or set MYSQL_ROOT_HOST=%
#   (only applied on first volume init — see MySQL note below).
# - MySQL credentials are applied ONLY on first volume initialization. If you change
#   MYSQL_ROOT_PASSWORD / MYSQL_USER / MYSQL_PASSWORD after the first deploy, update
#   users manually inside MySQL or reset the volume. The MySQL healthcheck validates
#   both root and MYSQL_USER — if deploy fails at mysql, credentials don't match the volume.
# - Mongo credentials are applied ONLY on first volume initialization. If you change
#   MONGO_ROOT_USERNAME / MONGO_ROOT_PASSWORD after the first deploy, the healthcheck
#   will fail until you either restore the original credentials or reset the volume.
# - Passwords with @, :, / or other special chars: do NOT put them raw in MONGO_URI.
#   Either leave MONGO_URI unset (backend/mongo-express build the connection safely)
#   or URL-encode the password (e.g. @ becomes %40).
# - To reset Mongo (DATA LOSS): stop the stack, remove volume
#   time3-pesquisasatisfacao-taduvd_mongo_data, then redeploy.
