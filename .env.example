# ==================== BANCO DE DADOS ====================
MYSQL_ROOT_PASSWORD=root_secure_password_change_me
MYSQL_USER=pesquisa
MYSQL_PASSWORD=secure_password_change_me
MYSQL_DATABASE=pesquisa_satisfacao

# ==================== BACKEND ====================
NODE_ENV=production
JWT_SECRET=your_jwt_secret_key_change_me
JWT_EXPIRATION=3600
DB_LOGGING=false

# URLs
FRONTEND_URL=http://localhost
CORS_ORIGIN=http://localhost

# Email (opcional)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@example.com
MAIL_PASS=your_app_password

# ==================== FRONTEND ====================
VITE_API_URL=/api
VITE_APP_NAME=Pesquisa e Satisfação
